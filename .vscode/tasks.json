{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Binary",
      "type": "shell",
      "command": "go",
      "args": ["build", "-o", "city2tabula", "./cmd"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$go"],
      "detail": "Compile the Go program into an executable binary."
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "go",
      "args": ["test", "-v", "./..."],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$go"],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "detail": "Run all tests with verbose output."
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "go test -coverprofile=coverage.out ./... && go tool cover -func=coverage.out"],
      "group": "test",
      "problemMatcher": ["$go"],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "detail": "Run all tests and print coverage percentage per function."
    },
    {
      "label": "Create Database",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd", "-create-db"],
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": false
      },
      "detail": "Create the complete City2TABULA database (CityDB + schemas + data import)."
    },
    {
      "label": "Reset Database",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd", "-reset-db"],
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": false
      },
      "detail": "Drop all schemas and recreate the complete database."
    },
    {
      "label": "Reset City2TABULA Schema",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd", "-reset-city2tabula"],
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": false
      },
      "detail": "Drop all schemas and recreate the complete City2TABULA schema."
    },
    {
      "label": "Extract Features",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd", "-extract-features"],
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": false
      },
      "detail": "Run the feature extraction pipeline."
    },
    {
      "label": "Run MkDocs server",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "python -m pip install -r docs/requirements.txt && python -m mkdocs serve"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "detail": "Start the MkDocs development server with live reload."
    }
  ]
}
